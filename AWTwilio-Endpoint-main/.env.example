MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/airwhisper
JWT_SECRET=<long-random-string>
JWT_REFRESH_SECRET=<different-long-random-string>
UPSTASH_REDIS_URL=redis://default:<token>@<host>.upstash.io:6379
RESEND_API_KEY=re_<key>
EMAIL_FROM=AirWhisper <noreply@yourdomain.com>
TWILIO_ACCOUNT_SID=AC<sid>
TWILIO_AUTH_TOKEN=<token>
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
GOOGLE_CLIENT_ID=<ios-client-id>.apps.googleusercontent.com
PORT=3000
